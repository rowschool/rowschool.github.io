{
  "name": "rowschool.com",
  "version": "1.0.0",
  "description": "The Results-Oriented Work School",
  "main": "server.js",
  "dependencies": {
    "bootstrap-icons": "^1.11.3",
    "commander": "^12.0.0",
    "concurrently": "^9.2.1",
    "handlebars": "^4.7.7",
    "js-beautify": "^1.14.0",
    "live-server": "^1.2.1",
    "mkdirp": "^3.0.1",
    "nodemon": "^2.0.15",
    "sass": "1.77.5",
    "showdown": "^1.9.1"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node server.js",
    "build-css": "sass --load-path=scss src/static/styles/main.scss styles/main.css",
    "watch-css": "nodemon --watch src/static/styles --ext scss --exec \"npm run build-css\"",
    "build-views": "node build/build.js -d cwd -p \"src/views/partials/**/*.hbs\" -l \"src/views/layouts/**/*.hbs\" -t \"src/views/templates/**/*.hbs\" -v",
    "watch-views": "nodemon --watch src/views --ext hbs --exec \"npm run build-views\"",
    "watch": "concurrently -k -n views,css -c cyan,yellow \"npm run watch-views\" \"npm run watch-css\"",
    "dev-build-and-watch": "npm run build-views && npm run build-css && npm run watch",
    "build-md": "node build/markdown-to-handlebars src/markdown/blog/ src/views/templates/blog/",
    "update-post": "npm run build-md",
    "clear-html": "rm *.html && rm **/*.html"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rowschool/rowschool.github.io.git"
  },
  "author": "Neil Thawani",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/rowschool/rowschool.github.io/issues"
  },
  "homepage": "https://github.com/rowschool/rowschool.github.io#readme"
}
